# Godebonner remote Supabase project (inkuubqwtzutaxaimjoc).
# Do NOT use a local Supabase stack, and do NOT copy credentials from the Subb project.
# Dashboard → Settings → API
VITE_SUPABASE_URL=

# Client-safe public key: prefer "publishable" from the dashboard (legacy name: anon key — same value/role)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional legacy env name if you already use it instead of VITE_SUPABASE_PUBLISHABLE_KEY
# VITE_SUPABASE_ANON_KEY=

# For `npm run supabase:link` and `npm run db:push` (Settings → General → Project ID)
# Godebonner project ref — not Subb:
SUPABASE_PROJECT_REF=inkuubqwtzutaxaimjoc

# First administrator: after one user signs up, run in SQL editor (replace UUID):
# update public.profiles set is_admin = true where id = '00000000-0000-0000-0000-000000000000';

# Automated tests (Vitest DB + Playwright) use a local Supabase stack only.
# See docs/TESTING.md — do not point test:db / test:e2e at the remote production project.
